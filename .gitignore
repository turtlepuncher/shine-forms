# Wrangler local state and cache. Regenerated by the CLI on every run and
# holds Cloudflare account state, so it must never be committed to this
# PUBLIC repo. (workers/stripe-checkout/.wrangler/ was tracked from
# 2026-03-14 until 2026-07-23.)
.wrangler/

# Local env files: the Worker's STRIPE_SECRET_KEY and LM_CLAIM_KEY are
# wrangler secrets and must never land on disk here.
.dev.vars
.env

# OS / editor noise
.DS_Store
node_modules/
